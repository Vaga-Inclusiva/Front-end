<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaCadastro">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jura"
        android:lineSpacingExtra="21dp"
        android:textStyle="bold"
        android:text="@string/cadastre_se"
        android:textAppearance="@style/cadastre_se"
        android:textColor="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.096" />

    <TextView
        android:id="@+id/ViewLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jura"
        android:lineSpacingExtra="21dp"
        android:text="@string/login"
        android:textAppearance="@style/cadastre_se"
        android:textColor="@color/primary"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.155"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.212" />

    <TextView
        android:id="@+id/ViewCadastro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jura"
        android:lineSpacingExtra="21dp"
        android:text="@string/cadastro"
        android:textAppearance="@style/cadastre_se"
        android:textColor="@color/primary"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.79"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.212" />

    <Button
        android:id="@+id/btn_register"
        android:layout_width="287dp"
        android:layout_height="61dp"
        android:backgroundTint="@color/primary"
        android:fontFamily="@font/jura"
        android:text="@string/cadastrar"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.817" />

    <EditText
        android:id="@+id/email"
        android:layout_width="308dp"
        android:layout_height="48dp"
        android:drawableStart="@drawable/email"
        android:ems="5"
        android:fontFamily="@font/jura"
        android:hint="@string/e_mail"
        android:lineSpacingExtra="21dp"
        android:textAppearance="@style/input"
        android:textColor="@color/primary"
        android:textColorHint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.364"
        android:inputType="textEmailAddress"
        android:autofillHints="" />

    <EditText
        android:id="@+id/senha"
        android:layout_width="308dp"
        android:layout_height="48dp"
        android:drawableStart="@drawable/lock"
        android:drawableEnd="@drawable/eyeclosed"
        android:ems="5"
        android:fontFamily="@font/jura"
        android:hint="@string/senha"
        android:inputType="textPassword"
        android:lineSpacingExtra="21dp"
        android:textAppearance="@style/input"
        android:textColor="@color/primary"
        android:textColorHint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.576"
        android:autofillHints="" />

    <EditText
        android:id="@+id/nome"
        android:layout_width="308dp"
        android:layout_height="48dp"
        android:drawableStart="@drawable/account_outline"
        android:ems="5"
        android:fontFamily="@font/jura"
        android:hint="@string/nome"
        android:lineSpacingExtra="21dp"
        android:textAppearance="@style/input"
        android:textColor="@color/primary"
        android:textColorHint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.471"
        android:inputType="text"
        android:autofillHints="" />

    <EditText
        android:id="@+id/confirmarsenha"
        android:layout_width="308dp"
        android:layout_height="48dp"
        android:drawableStart="@drawable/lock"
        android:drawableEnd="@drawable/eyeclosed"
        android:ems="5"
        android:fontFamily="@font/jura"
        android:hint="@string/confirmar_senha"
        android:inputType="textPassword"
        android:lineSpacingExtra="21dp"
        android:textAppearance="@style/input"
        android:textColor="@color/primary"
        android:textColorHint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.683"
        android:autofillHints="" />

</androidx.constraintlayout.widget.ConstraintLayout>